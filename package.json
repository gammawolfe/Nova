{
  "name": "nova-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:agent-card": "tsx scripts/generate-agent-card.ts",
    "generate:keys": "tsx scripts/generate-keys.ts",
    "seed-tenant": "tsx scripts/seed-tenant.ts",
    "mock:operator": "tsx scripts/mock-operator.ts",
    "mock:reply": "tsx scripts/mock-reply-receiver.ts",
    "test:acceptance": "tsx scripts/acceptance-test-m1.ts",
    "test:acceptance:m2": "tsx scripts/acceptance-test-m2.ts",
    "did:exchange": "tsx scripts/did-exchange.ts",
    "issue:ucan": "tsx scripts/issue-ucan.ts",
    "revoke:ucan": "tsx scripts/revoke-ucan.ts",
    "lint": "eslint packages/*/src/**/*.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.5.0"
  }
}
